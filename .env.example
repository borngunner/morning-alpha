APP_PIN=change-this-pin
SESSION_SECRET=change-this-long-random-text
PUBLIC_APP_URL=https://your-vercel-app.vercel.app

# Kakao Talk message API
KAKAO_REST_API_KEY=
KAKAO_CLIENT_SECRET=
KAKAO_ACCESS_TOKEN=
KAKAO_REFRESH_TOKEN=

# 1 = Vercel Cron sends Kakao summary after the 07:00 report.
# 0 = generate the report only.
KAKAO_DAILY_SEND=0

# Secret keys for manual automation calls.
KAKAO_SEND_SECRET=change-this-random-send-key
CRON_SECRET=change-this-random-cron-key
